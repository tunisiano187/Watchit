{
  "name": "watchit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && npx esbuild src/workers/index.ts --bundle --platform=node --format=cjs --outfile=dist/workers/index.cjs",
    "start": "next start",
    "lint": "eslint .",
    "worker": "node dist/workers/index.cjs",
    "worker:dev": "tsx watch src/workers/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "bullmq": "^5.34.0",
    "dockerode": "^4.0.2",
    "drizzle-orm": "^0.36.4",
    "franc-min": "^6.2.0",
    "ioredis": "5.10.1",
    "next": "14.2.35",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^3.26.1",
    "nodemailer": "^7.0.7",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.29",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "drizzle-kit": "^0.28.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
