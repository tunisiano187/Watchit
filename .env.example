# PostgreSQL
DATABASE_URL=postgresql://watchit:changeme@localhost:5432/watchit
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# Vane (internal search API — configure provider IDs via Vane's own settings UI)
VANE_URL=http://vane:3001
VANE_CHAT_PROVIDER_ID=openai
VANE_CHAT_MODEL_KEY=gpt-4o-mini
VANE_EMBEDDING_PROVIDER_ID=openai
VANE_EMBEDDING_MODEL_KEY=text-embedding-3-small

# Ollama (local topic extraction)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b

# Email tracking (base URL used in email links — must be publicly reachable)
TRACKING_BASE_URL=http://localhost:3000

# Internal API key (protects /api/internal/* routes)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=replace-with-a-random-secret

# Set to true to allow new user registrations
ALLOW_SIGNUP=false

# Email address granted admin access regardless of ALLOW_SIGNUP
ADMIN_EMAIL=admin@example.com

# i18n defaults
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,fr

# Docker / auto-updater
COMPOSE_PROJECT_NAME=watchit
GITHUB_REPO=tunisiano187/Watchit
# Optional: GitHub personal access token (increases API rate limit for update checks)
GITHUB_TOKEN=

# ── Analytics (Umami) — opt-in ────────────────────────────────────────────────
# 1. Start Umami:  docker compose --profile analytics up -d
# 2. Visit http://host:3002, log in (admin / umami), change the password
# 3. Add your site → copy the Website ID below
# 4. Set NEXT_PUBLIC_UMAMI_URL to the public URL of your Umami instance
#    (must be reachable by visitors' browsers, e.g. https://analytics.example.com)
# 5. Rebuild watchit:  docker compose build watchit && docker compose up -d watchit
#
# To make your stats public: in Umami UI → Settings → Website → Share URL → Enable
#
# Generate UMAMI_SECRET with: openssl rand -hex 32
UMAMI_SECRET=
UMAMI_PORT=3002
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=http://localhost:3002
